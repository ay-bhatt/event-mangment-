# Backend API (proxied to /api in dev; set full URL in production)
VITE_API_URL=/api

# EmailJS (optional — send volunteer pass)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# App base URL for QR verify links (optional, defaults to window origin)
VITE_APP_BASE_URL=http://localhost:5173

# Admin accounts are stored in MySQL — run: cd backend && npm run seed

# Server
NODE_ENV=production
PORT=3001
API_BASE_PATH=/api

# MySQL (cPanel: use credentials from MySQL Databases)
DB_HOST=localhost
DB_PORT=3306
DB_USER=vldxjhks_db_user
DB_PASSWORD=your_db_password
DB_NAME=vldxjhks_caumas_eventmanager

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=24h

# CORS — your frontend domain (comma-separated for multiple)
# Include local dev host(s) here to allow login from http://localhost:5173
CORS_ORIGIN=https://eventmanager.caumas.com,http://localhost:5173,http://127.0.0.1:5173

# Default event
DEFAULT_EVENT_SLUG=jatra-2026
DEFAULT_EVENT_NAME= Festival 
